TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://localhost:3000/callback
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=

# Broadcaster account token for direct Channel Points redemptions.
TWITCH_BROADCASTER_ACCESS_TOKEN=
TWITCH_BROADCASTER_REFRESH_TOKEN=

# Dedicated bot account
TWITCH_BOT_USERNAME=
TWITCH_BOT_USER_ID=

# Channel where the bot should listen and speak
TWITCH_CHANNEL_NAME=
TWITCH_CHANNEL_ID=

# Comma-separated Twitch usernames with owner permissions.
BOT_OWNERS=

# Optional Spotify integration for !song and !sr.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

# Overlay control API used by !overlay commands.
# Local development: http://127.0.0.1:5174
# VPS production: http://127.0.0.1:5173
OVERLAY_CONTROL_URL=http://127.0.0.1:5173
